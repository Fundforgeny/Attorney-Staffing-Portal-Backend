<% content_for :title do %>Reset Password<% end %>

<div id="main_content_wrapper">
  <div id="main_content">

    <% if flash[:error].present? %>
      <div class="flash flash_error"><%= flash[:error] %></div>
    <% end %>

    <div class="panel">
      <h3>Reset Password for <%= @admin_user.email %></h3>
      <div class="panel_contents">
        <%= form_tag(reset_password_admin_admin_user_path(@admin_user), method: :post) do %>
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

          <div class="input" style="margin-bottom: 16px;">
            <%= label_tag :new_password, "New Password", style: "display:block; font-weight:bold; margin-bottom:4px;" %>
            <%= password_field_tag :new_password, "",
                  placeholder: "Minimum 8 characters",
                  autocomplete: "new-password",
                  style: "padding:8px; width:300px; border:1px solid #ccc; border-radius:4px;" %>
          </div>

          <div class="input" style="margin-bottom: 20px;">
            <%= label_tag :new_password_confirmation, "Confirm New Password", style: "display:block; font-weight:bold; margin-bottom:4px;" %>
            <%= password_field_tag :new_password_confirmation, "",
                  autocomplete: "new-password",
                  style: "padding:8px; width:300px; border:1px solid #ccc; border-radius:4px;" %>
          </div>

          <div style="display:flex; gap:12px; align-items:center;">
            <%= submit_tag "Reset Password",
                  style: "background:#3498db; color:#fff; padding:10px 20px; border:none; border-radius:4px; cursor:pointer; font-size:14px; font-weight:bold;" %>
            <%= link_to "Cancel", admin_admin_user_path(@admin_user),
                  style: "color:#666; text-decoration:none; font-size:14px;" %>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</div>
