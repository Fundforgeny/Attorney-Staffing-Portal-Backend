<% content_for :title, "Reset Password — #{@admin_user.email}" %>

<div class="panel">
  <h3>Reset Password for <strong><%= @admin_user.email %></strong></h3>

  <% if flash[:error] %>
    <div class="flash flash_error"><%= flash[:error] %></div>
  <% end %>

  <%= form_tag reset_password_admin_admin_user_path(@admin_user), method: :post do %>
    <div class="panel_contents">
      <fieldset class="inputs">
        <ol>
          <li class="input string required">
            <label for="new_password">New Password <abbr title="required">*</abbr></label>
            <%= password_field_tag :new_password, nil,
                  id: "new_password",
                  class: "input-text",
                  autocomplete: "new-password",
                  placeholder: "Minimum 8 characters",
                  required: true %>
          </li>
          <li class="input string required">
            <label for="new_password_confirmation">Confirm New Password <abbr title="required">*</abbr></label>
            <%= password_field_tag :new_password_confirmation, nil,
                  id: "new_password_confirmation",
                  class: "input-text",
                  autocomplete: "new-password",
                  placeholder: "Re-enter new password",
                  required: true %>
          </li>
        </ol>
      </fieldset>

      <fieldset class="actions">
        <ol>
          <li class="action input_action">
            <%= submit_tag "Reset Password", class: "button" %>
            &nbsp;
            <%= link_to "Cancel", admin_admin_user_path(@admin_user), class: "button" %>
          </li>
        </ol>
      </fieldset>
    </div>
  <% end %>
</div>
